body {
    margin: 0;
    font-family: Arial, sans-serif;
    background-color: #0f172a;
    color: #e2e8f0;
}

/* HEADER */
header {
    background-color: #020617;
    padding: 15px;
    text-align: center;
}

header h1 {
    margin: 0;
}

header nav {
    margin-top: 10px;
}

header a {
    margin: 0 10px;
    color: #38bdf8;
    text-decoration: none;
}

header a:hover {
    text-shadow: 0 0 10px;
}

/* CONTAINER */
.container {
    display: flex;
    flex-direction: column;
}

/* HERO */
.hero {
    text-align: center;
    padding: 30px 20px;
}

/* SERVICES */
.services {
    padding: 20px;
}

.services article {
    background-color: #1e293b;
    margin: 10px 0;
    padding: 15px;
    border-radius: 8px;
}

/* ASIDE */
aside {
    background-color: #020617;
    padding: 15px;
    margin: 10px;
    border-left: 4px solid #38bdf8;
}

/* FORM */
.formulario {
    padding: 20px;
}

input, textarea {
    width: 100%;
    margin: 8px 0;
    padding: 10px;
    border-radius: 5px;
    border: none;
}

/* BUTTON */
button {
    padding: 10px;
    border: none;
    background-color: #38bdf8;
    color: black;
    cursor: pointer;
    border-radius: 5px;
}

button:hover {
    background-color: #0ea5e9;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 15px;
    background-color: #020617;
}
