<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vitor Dev</title>
    <link rel="stylesheet" href="estudo.css">
</head>
<body>

<header>
    <h1>Vitor Dev</h1>
    <nav>
        <a href="#">Início</a>
        <a href="#">Serviços</a>
        <a href="#">Contato</a>
    </nav>
</header>

<main class="container">

    <section class="hero">
        <h2>Criação de Sites</h2>
        <p>Transformo ideias em páginas modernas e funcionais.</p>
        <button>Saiba mais</button>
    </section>

    <section class="services">
        <h2>Serviços</h2>

        <article>
            <h3>Sites Responsivos</h3>
            <p>Sites que funcionam em celular e computador.</p>
        </article>

        <article>
            <h3>Manutenção</h3>
            <p>Atualizações e melhorias no seu site.</p>
        </article>
    </section>

    <aside>
        <h3>Dica</h3>
        <p>Entre em contato para orçamento rápido.</p>
    </aside>

    <section class="formulario">
        <h2>Contato</h2>

        <form>
            <label for="nome">Nome</label>
            <input type="text" id="nome" name="nome" required>

            <label for="email">Email</label>
            <input type="email" id="email" name="email" required>

            <label for="mensagem">Mensagem</label>
            <textarea id="mensagem" name="mensagem"></textarea>

            <button type="submit">Enviar</button>
        </form>
    </section>

</main>

<footer>
    <p>© 2026 Vitor</p>
</footer>

</body>
</html>
